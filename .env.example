# Copy this file to .env and edit values as needed.
# The app loads .env from the project root without external dependencies.

HOST=127.0.0.1
PORT=8000

# Set this in production. Generate with:
# python3 -c "import secrets; print(secrets.token_urlsafe(48))"
STUDYMATE_SECRET_KEY=change-me

# Optional runtime paths. Keep these outside the public repo on a server.
STUDYMATE_DB_PATH=instance/studymate.sqlite3
STUDYMATE_SECRET_PATH=instance/secret.key

# Enable only when the app is served through HTTPS.
STUDYMATE_COOKIE_SECURE=0

# DeepSeek API Key for AI matching
DEEPSEEK_API_KEY=""
